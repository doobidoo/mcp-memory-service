## Team deployment env — copy to tools/docker/.env and fill in.
## Used by tools/docker/docker-compose.traefik.yml.
##
## Network conventions (matches existing containers on this Traefik host):
##   - external network: web
##   - entrypoint:       web (port 80; TLS handled upstream of Traefik)
##   - no certresolver labels — Let's Encrypt termination is not done by
##     this Traefik instance, it's done at the edge for *.hive.letzdoo.com

## REQUIRED ─────────────────────────────────────────────────────────────────
## Single shared API key for all 10 devs. Clients send:
##   Authorization: Bearer <MCP_API_KEY>
## Generate with: openssl rand -hex 32
MCP_API_KEY=replace-me-with-openssl-rand-hex-32

## Hostname Traefik routes to this service.
MCP_PUBLIC_HOST=benites-memory.hive.letzdoo.com

## OPTIONAL ─────────────────────────────────────────────────────────────────
## Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

## pgvector backend ────────────────────────────────────────────────────────
## Required only when layering tools/docker/docker-compose.postgres.yml.
## See README + CLAUDE.md "Way of Working — Deploy Workflow" for the full
## docker compose -f ... -f ... command.
##
##   POSTGRES_PASSWORD     superuser password for the mcp-memory-postgres container
##   MCP_PGVECTOR_DSN      override DSN if pointing at an external Postgres
##                         (default: postgresql://mcp_memory:$POSTGRES_PASSWORD@mcp-memory-postgres:5432/mcp_memory)
##   MCP_PGVECTOR_SCHEMA   schema name (default: public)
POSTGRES_PASSWORD=replace-me-with-openssl-rand-hex-32
# MCP_PGVECTOR_DSN=postgresql://user:pass@host:5432/dbname
# MCP_PGVECTOR_SCHEMA=public
